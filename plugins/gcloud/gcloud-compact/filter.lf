#!/usr/bin/env lowfat-filter
# gcloud-compact — compact gcloud CLI output for LLM contexts.
# env: $sub $level $exit $args
#
# gcloud's default text output is tabular (instances/services/operations) and
# the deploy/operation flows print progress. Structured output (--format json|
# yaml) is machine-readable and MUST pass through byte-exact. On a non-zero exit
# the error / stack must show — raw.

*:
    if exit failed:
        raw
    elif --format json:
        raw
    elif --format yaml:
        raw
    else:
        match level:
            ultra: head 25
            lite:  head 200
            else:  head 60
