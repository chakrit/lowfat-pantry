#!/usr/bin/env lowfat-filter
# rspec-compact — collapse passing runs to the tally; on failure keep the
# Failures section, the error block, the summary and the rerun list, drop the
# progress dots and timing chatter.
# env: $sub $level $exit $args

# Any explicit --format/-f (json, html, junit, a custom formatter class) is
# caller-chosen machine output — pass byte-exact (invariant 1). The default
# progress format (no flag) is the common case and still compacts below.
*:
    if --format:
        raw
    elif -f:
        raw
    elif exit ok:
        keep /examples?, \d+ failures?/
        head 1
        or "rspec: passed"
    else:
        match level:
            ultra:
                keep /(^\s+\d+\) |Failure\/Error|^rspec .*#|examples?, .*(failure|error)|LoadError|cannot load|An error occurred)/
                head 30
                or-shell: tail -20
            lite:
                drop /^Finished in /
                drop /^[.FE*]+$/
                head 200
            full:
                drop /^Finished in /
                drop /^[.FE*]+$/
                drop /^\s*$/
                head 60
                or-shell: tail -40
