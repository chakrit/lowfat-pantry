#!/usr/bin/env lowfat-filter
# eslint-compact — compact ESLint stylish output for LLM contexts.
# env: $sub $level $exit $args
#
# ESLint exit: 0 = clean (no output), 1 = lint problems, 2 = config crash.
# Guards only see ok/failed (not 1-vs-2), so we never keyword-filter — a crash
# message would be dropped and silently look "clean". Instead we just drop blank
# separator lines and head-cap: the bloat is the *number* of problems across
# files, and stylish output is already one line per problem. The `✖ N problems`
# summary survives unless the list is enormous. Empty input (exit 0) → "clean".
#
# Pass `--format json`/`-f json` straight through — machine-readable.

define dense:
    drop /^[[:space:]]*$/

# cap that announces itself — eslint can't keyword-keep the `✖ N problems`
# summary (no 1-vs-2 exit signal), so a head-cap of an enormous list drops the
# summary too; the hint tells the agent the findings were truncated.
define cap(limit):
    shell: awk -v lim=$1 'NR<=lim; END { if (NR>lim) printf "... (%d lines total)\n", NR }'

*:
    if --format json:
        raw
    elif -f json:
        raw
    else:
        match level:
            ultra:
                dense
                cap 25
                or "eslint: clean"
            lite:
                dense
                cap 200
                or "eslint: clean"
            else:
                dense
                cap 60
                or "eslint: clean"
